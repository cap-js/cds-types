{
  "include": ["*.ts"],
  "compilerOptions": {
    "module": "nodenext",
    "target": "ES2022",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "moduleResolution": "nodenext",
    "noEmit": true,
    "noImplicitAny": true
  },
  "exclude": [
    "node_modules"
  ],
  "paths": {
    "@sap/cds": ["./node_modules/@cap-js/cds-types"]
  }
}