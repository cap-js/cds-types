{
  "include": ["*.ts"],
  "compilerOptions": {
    "module": "ES2022",
    "target": "ES2022",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "moduleResolution": "node",
    "noEmit": true,
    "noImplicitAny": true,
    "baseUrl": "../../../..",
    "paths": {
      "@sap/cds": ["apis/cds.d.ts", "dist/cds-types.d.ts"]
    }
  },
  "exclude": [
    "node_modules"
  ]
}